# Optional local overrides for the shell scripts.
# Copy to .env and adjust only if you need custom paths or binaries.

PODMAN_BIN=podman
TOOLBOX_BIN=toolbox
JUPYTER_BIND_HOST=127.0.0.1
HF_HUB_DISABLE_XET=1
HF_HUB_ENABLE_HF_TRANSFER=0

